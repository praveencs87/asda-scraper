{
  "title": "Asda Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "startUrls": {
      "title": "Start URLs",
      "type": "array",
      "description": "List of Asda category or search URLs to scrape.",
      "editor": "requestListSources",
      "prefill": [
        { "url": "https://groceries.asda.com/search/milk" }
      ]
    },
    "maxItems": {
      "title": "Max Items",
      "type": "integer",
      "description": "Maximum number of items to extract.",
      "default": 100,
      "minimum": 1
    },
    "proxyConfig": {
      "title": "Proxy Configuration",
      "type": "object",
      "description": "Select proxies to be used.",
      "editor": "proxy",
      "default": {
        "useApifyProxy": true
      }
    }
  },
  "required": [
    "startUrls"
  ]
}